# --- centrifuge ---
# Copy to .env and adjust. This file documents every var the app and the
# local-dev docker-compose understand. (Local dev only — production wiring lives
# elsewhere and is not represented here.)

# Connection to Postgres. For docker-compose this resolves to the bundled
# `postgres` service; for local non-docker dev, point it at a local Postgres.
# The compose file builds this string from the POSTGRES_* vars below.
DATABASE_URL=postgres://centrifuge:centrifuge@localhost:5432/centrifuge?sslmode=disable

# Separate database used by the test suite so tests never touch dev data.
# Create with:  CREATE DATABASE centrifuge_test OWNER centrifuge;
DATABASE_URL_TEST=postgres://centrifuge:centrifuge@localhost:5432/centrifuge_test?sslmode=disable

# Base URL of the Ollama server used for relevance scoring/summarization.
# Ollama is NOT bundled in compose — gemma4:31b runs on the LAN host.
OLLAMA_URL=http://imperial-construct:11434

# Ollama model to use.
OLLAMA_MODEL=gemma4:31b

# Per-request timeout (seconds) for one generate call. The model is heavy and a
# large digest can take minutes on gemma4:31b, so this is generous (matches the
# imperium-loop 15-min Ollama timeout precedent); the worker requeues on timeout
# rather than dropping the newsletter.
OLLAMA_TIMEOUT_SECONDS=900

# How many times a transient Ollama failure (network / 5xx) is retried.
OLLAMA_MAX_RETRIES=2

# Cap on tokens generated per scoring call (Ollama num_predict). Bounds output so
# a model that fails to close its JSON truncates fast (→ salvage) instead of
# running to the context limit / timeout and looping. ~6k covers a large digest;
# keep its worst-case runtime (num_predict / ~22 tok-s) below OLLAMA_TIMEOUT_SECONDS
# so a runaway truncates rather than times out. 0 = unbounded.
OLLAMA_NUM_PREDICT=6144

# Shared secret required on the ingest endpoints. Leave blank to disable auth in
# local dev, or set a value and pass it in the X-Ingest-Token header (or a
# ?token= query param).
INGEST_TOKEN=

# Cap on the cleaned body text derived from each newsletter and fed to the
# scorer, so a large digest can't blow the model's context window. 0 = no limit.
INGEST_MAX_CHARS=24000

# Port the HTTP server listens on.
PORT=8080

# Log verbosity: debug | info | warn | error.
LOG_LEVEL=info

# Comma-separated list of topics the relevance scorer cares about.
RELEVANCE_TOPICS=AI engineering,urbanism,transit/trains,nuclear,tech,video games

# --- read API (backs the UI: CTFG-26 / CTFG-27) ---
# Access-Control-Allow-Origin served by the read endpoints for the browser
# frontend. "*" is fine while the API carries no credentials; set a specific
# origin to lock it down.
CORS_ALLOW_ORIGIN=*

# Externally reachable base URL, used for absolute links in /feed.xml. Leave
# blank to derive scheme+host from each request (honors X-Forwarded-Proto).
PUBLIC_BASE_URL=

# --- scoring worker ---
# The decoupled background worker that polls pending newsletters, scores them
# via Ollama, and persists stories. Set false to disable (e.g. local dev with no
# reachable Ollama).
SCORING_ENABLED=true

# How often (seconds) the worker polls for newsletters awaiting scoring.
SCORING_INTERVAL_SECONDS=30

# How many newsletters the worker claims per poll. The model is single-heavy, so
# a batch is processed sequentially.
SCORING_BATCH_SIZE=5

# --- postgres (used by docker-compose) ---
# These configure the bundled postgres:16-alpine service and are also
# substituted into DATABASE_URL inside docker-compose.yaml.
POSTGRES_USER=centrifuge
POSTGRES_PASSWORD=centrifuge
POSTGRES_DB=centrifuge
